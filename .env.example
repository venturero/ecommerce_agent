# Required for chat sessions in production (generate a long random string).
FLASK_SECRET_KEY=change_me_in_production

LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
SHOPPING_RESULTS_PER_QUERY=12
MIN_RECOMMENDED_LINKS=4
RELEVANCE_MIN_SCORE=0.38
RELEVANCE_CLARIFY_MAX_SCORE=0.48
MAX_RECOMMENDED_LINKS=5
MAX_IMMERSIVE_LOOKUPS=4
USD_TO_TRY_RATE=45.54
USE_AMAZON_SEARCH=true
USE_TRENDYOL_NATIVE=true
USE_TRENDYOL_SERPAPI_FALLBACK=true
TRENDYOL_FALLBACK_MIN_RESULTS=3
TRENDYOL_MAX_RESULTS_PER_QUERY=24
TRENDYOL_REQUEST_TIMEOUT=30
SERP_API_KEY=your_serpapi_key_here

# SQLite path for impressions, clicks, preferences, and chat latency/failure metrics.
EVENT_DB_PATH=data.db
